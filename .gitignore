# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log
dev-server.*.log

# dados locais sensíveis (banco com hashes/segredos) e conteúdo de usuário
/data/
/public/uploads/
# downloads: ignora tudo, EXCETO os instaladores do agente (servidos pelo site, via Git LFS)
/public/downloads/*
!/public/downloads/agent/
# intermediários de build do instalador (wix/stage) não vão pro git
/public/downloads/agent/stage/

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# agent build artifacts
/agent/dist/
/agent/wix/tools/
/agent/stub/NexusDeskSetupStub.exe
/agent-desktop/node_modules/
/agent-desktop/dist/

