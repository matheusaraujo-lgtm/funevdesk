MESHCENTRAL_URL=http://localhost:4430

# Motor de inteligência (opcional). Sem chave, o sistema usa apenas as regras
# internas (linguagem simples + ações). Com chave, o DeepSeek refina os textos.
# Crie a chave em https://platform.deepseek.com/ (modelo deepseek-chat / V3).
# DEEPSEEK_API_KEY=

# Segurança (XDR/EPP). A Central de Segurança lê alertas da tabela xdr_alerts.
# Ingestão push (sistemas externos enviam alertas via POST /api/xdr/ingest):
# XDR_INGEST_SECRET=
# Conectores pull (sem credenciais, retornam vazio — nunca inventam dados):
# DEFENDER_TENANT_ID=
# DEFENDER_CLIENT_ID=
# DEFENDER_CLIENT_SECRET=
# SENTINELONE_API_URL=
# SENTINELONE_TOKEN=
