<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2011/08/nuspec.xsd">
  <metadata>
    <id>wix</id>
    <version>3.14.1</version>
    <title>WiX Toolset</title>
    <authors>WiX Toolset Team</authors>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <license type="expression">MS-RL</license>
    <licenseUrl>https://licenses.nuget.org/MS-RL</licenseUrl>
    <icon>wix.png</icon>
    <projectUrl>http://wixtoolset.org/</projectUrl>
    <description>This package bundles the official WiX v3 binaries as a nupkg, with all binaries under tools.
      An MSBuild .props file automatically resolves a v3 .wixproj targets and paths to that location.
      This allows build scripts to just install this package to build MSIs without requiring
      additional software on a build server.</description>
    <copyright>Copyright (c) .NET Foundation and contributors. All rights reserved.</copyright>
    <tags>wix msi setup install</tags>
  </metadata>
</package>