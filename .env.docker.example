# Copie para .env e ajuste conforme necessário:
# cp .env.docker.example .env

# PostgreSQL (usado pelo docker-compose)
POSTGRES_USER=nexus
POSTGRES_PASSWORD=nexus_dev
POSTGRES_DB=nexus_desk
DATABASE_URL=postgresql://nexus:nexus_dev@postgres:5432/nexus_desk

# URL pública do MeshCentral (acessível pelos agentes Windows no host)
MESHCENTRAL_URL=http://localhost:4430

# Redis (reservado para filas futuras)
REDIS_URL=redis://redis:6379

# Motor de inteligência (opcional). Sem chave, usa apenas as regras internas.
# Com chave, o DeepSeek (deepseek-chat / V3) refina os textos dos alertas.
# DEEPSEEK_API_KEY=

# Desenvolvimento local sem Docker (SQLite)
# DATABASE_URL=
# MESHCENTRAL_URL=http://localhost:4430
