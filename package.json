{
  "name": "nexus-desk",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "seed:demo": "node scripts/seed-demo.cjs",
    "test:e2e": "node scripts/e2e-smoke.mjs",
    "build:agent-stub": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-agent-stub.ps1",
    "prepare:agent": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-agent-stub.ps1 && node scripts/generate-stub-module.mjs",
    "test:agent-packager": "node scripts/test-agent-packager.mjs",
    "build:agent": "node scripts/build-agent-electron.mjs",
    "build:agent:legacy": "node scripts/build-agent-packages.mjs",
    "validate:agent": "node scripts/validate-agent-build.mjs",
    "validate:agent:docker": "node scripts/validate-agent-docker.mjs",
    "install:agent": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/upgrade-agent.ps1",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
