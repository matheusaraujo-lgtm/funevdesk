# ============================================================================
# FunevDesk — Configuração de PRODUÇÃO
# Copie para .env e preencha os valores. NUNCA versione o .env real.
#   cp .env.production.example .env
# Gere segredos fortes com:  openssl rand -base64 32
# ============================================================================

# --- Banco de dados (PostgreSQL) -------------------------------------------
# POSTGRES_PASSWORD é OBRIGATÓRIO (o compose recusa subir sem ele).
# O app monta DATABASE_URL a partir destes valores apontando para o serviço "postgres".
POSTGRES_USER=nexus
POSTGRES_PASSWORD=TROQUE_POR_UMA_SENHA_FORTE
POSTGRES_DB=nexus_desk
# SSL entre app e Postgres: "false" na rede interna do compose (ambos no mesmo host).
DATABASE_SSL=false

# --- Segurança da aplicação ------------------------------------------------
# Senha inicial do admin (admin@local). Se vazia, uma aleatória é gerada e
# impressa UMA vez no log do container. Troca obrigatória no primeiro login.
NEXUS_SEED_PASSWORD=TROQUE_POR_UMA_SENHA_FORTE

# Cookie de sessão Secure (exige HTTPS). MANTENHA "true" em produção atrás do
# reverse proxy com TLS. Use "false" APENAS em teste sem HTTPS (inseguro).
SESSION_COOKIE_SECURE=true

# Hosts autorizados a serem embutidos no instalador do agente (separados por vírgula).
# Evita gerar um agente que reporte a um servidor malicioso. Use seu domínio público.
# O próprio host do request já é sempre autorizado; isto cobre domínios adicionais.
AGENT_ALLOWED_SERVER_HOSTS=funevdesk.funev.org.br

# --- Rede / reverse proxy --------------------------------------------------
# Em que interface o container publica a porta do app (o TLS fica no nginx).
#   APP_BIND=127.0.0.1  -> nginx no MESMO host (recomendado: nada exposto na rede).
#   APP_BIND=0.0.0.0    -> nginx em OUTRO host. Neste caso, RESTRINJA no firewall:
#                          ufw allow from <IP_DO_NGINX> to any port 3000
APP_BIND=0.0.0.0
APP_PORT=3000

# Segredo do endpoint de ingestão XDR (/api/xdr/ingest). Gere um valor aleatório.
XDR_INGEST_SECRET=

# --- Integrações opcionais (deixe vazio para desativar) --------------------
# Motor de inteligência (refina textos dos alertas/chamados). Sem chave, usa só as regras internas.
DEEPSEEK_API_KEY=

# Permitir webhooks para IPs privados (necessário se os destinos ficam na LAN interna).
# Padrão seguro é desativado; ative só se precisar.
WEBHOOK_ALLOW_PRIVATE=

# Conector Microsoft Defender (XDR)
DEFENDER_TENANT_ID=
DEFENDER_CLIENT_ID=
DEFENDER_CLIENT_SECRET=

# Conector SentinelOne (XDR)
SENTINELONE_API_URL=
SENTINELONE_TOKEN=

# URL pública do MeshCentral (acesso remoto), se usado.
# MESHCENTRAL_URL=https://mesh.suaempresa.com.br
